# API service port
PORT=4000
# Webhook gateway port
WEBHOOK_PORT=4100
# Worker health endpoint port
WORKER_HEALTH_PORT=4200
# Scheduler health endpoint port
SCHEDULER_HEALTH_PORT=4300
# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/claricore
# Redis connection string used by BullMQ
REDIS_URL=redis://localhost:6379
# BullMQ queue name
QUEUE_NAME=sync-jobs
# Service log level (info|error)
LOG_LEVEL=info
# 32-byte hex string for AES-256-GCM credentials encryption
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# Shared webhook HMAC secret (stub verification)
WEBHOOK_SIGNATURE_SECRET=dev-webhook-secret
