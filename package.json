{
  "name": "claricore-connectors",
  "private": true,
  "version": "0.4.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "bootstrap": "pnpm install && pnpm build",
    "generate:connector": "tsx scripts/generate-connector.ts",
    "validate:manifests": "tsx scripts/validate-manifests.ts",
    "db:migrate": "pnpm --filter @claricore/db migrate",
    "db:seed": "pnpm --filter @claricore/db seed"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "connectors/*"
  ]
}
